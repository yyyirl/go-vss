FROM skeyevss_sev_base

ARG SKEYEVSS_DB_GRPC_NAME
ARG SKEYEVSS_VSS_NAME
ARG SKEYEVSS_BACKEND_API_NAME
ARG SKEYEVSS_CRON_NAME
ARG SKEYEVSS_WEB_SEV_NAME
ARG SKEYEVSS_MEDIA_SERVER_NAME

# 工作目录
WORKDIR /app

RUN mkdir -p /app
COPY docker/. /app/
RUN chmod +x /app/$SKEYEVSS_DB_GRPC_NAME
RUN chmod +x /app/$SKEYEVSS_VSS_NAME
RUN chmod +x /app/$SKEYEVSS_BACKEND_API_NAME
RUN chmod +x /app/$SKEYEVSS_CRON_NAME
RUN chmod +x /app/$SKEYEVSS_WEB_SEV_NAME
RUN chmod +x /app/$SKEYEVSS_MEDIA_SERVER_NAME

CMD ["tail", "-f", "/dev/null"]